[user]
	name = Walker Hale IV
	email = walker.hale.iv@gmail.com

[alias]
	al = config --get-regexp ^alias\\.
	bc = bundle create
	bl = bundle list-heads
	br = branch
	brav = "!git -P br -av"
	ci = commit
	co = checkout
	cp = cherry-pick
	df = diff
	ff = merge --ff-only
	ft = fetch
	fp = fetch -p
	lg = log --graph --decorate --date=format:'%F %T' --pretty=tformat:'%C(auto)%cd %h %d %s'
	lsr = ls-remote
	rb = rebase
	rp = rev-parse
	rs = reset
	st = status
	wt = worktree
[color]
	diff = auto
	status = auto
	branch = auto
	ui = true
[color "diff"]
	meta = 11
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[core]
	excludesfile = /Users/hale/.gitignore_global
	editor = /usr/local/bin/code -w
[credential]
	helper = cache
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = main
[pull]
	ff = only

[github]
	user = walkerh
	token = 5fe11ef2e3bd6eceeddafb6e43cfa203

# Start UI things...

# For delta
[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta
[interactive]
    diffFilter = delta --color-only --features=interactive
[delta]
    features = decorations interactive navigate
    side-by-side = true
[delta "interactive"]
    keep-plus-minus-markers = false
[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = "#067a00"
    hunk-header-style = file line-number syntax
[cola]
	spellcheck = false
